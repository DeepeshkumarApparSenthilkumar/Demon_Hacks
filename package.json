{
  "name": "chitrade",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix server && npm install --prefix client",
    "dev": "concurrently --kill-others-on-fail --prefix-colors \"yellow,cyan\" --names \"SERVER,CLIENT\" \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "build": "npm run build --prefix client",
    "setup": "npm run install:all && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
